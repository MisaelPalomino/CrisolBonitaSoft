    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.producto ){",
        "\treturn {",
        "\t\t//map producto variable to expected task contract input",
        "\t\tproductoInput: {",
        "\t\t\tcodigo: $data.producto.codigo !== undefined ? $data.producto.codigo : null,",
        "\t\t\tnombre: $data.producto.nombre !== undefined ? $data.producto.nombre : null,",
        "\t\t\testado: $data.producto.estado !== undefined ? $data.producto.estado : null,",
        "\t\t\tisbn: $data.producto.isbn !== undefined ? $data.producto.isbn : null,",
        "\t\t\tcategoria: $data.producto.categoria !== undefined ? $data.producto.categoria : null,",
        "\t\t\tprecio: $data.producto.precio !== undefined ? $data.producto.precio : null,",
        "\t\t\tstock: $data.producto.stock !== undefined ? $data.producto.stock : null,",
        "\t\t\tcantidadDisponible: $data.producto.cantidadDisponible !== undefined ? $data.producto.cantidadDisponible : null",
        "\t\t},",
        "\t\trecepcionConformeInput: $data.formInput.recepcionConformeInput",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "producto" : {
      "type" : "url",
      "value" : [
        "../{{context.producto_ref.link}}"
      ],
      "exposed" : false
    },
    "taskId" : {
