    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.clienteVar ){",
        "\treturn {",
        "\t\t//map clienteVar variable to expected task contract input",
        "\t\tclienteVarInput: {",
        "\t\t\tnombre: $data.clienteVar.nombre !== undefined ? $data.clienteVar.nombre : null,",
        "\t\t\temail: $data.clienteVar.email !== undefined ? $data.clienteVar.email : null,",
        "\t\t\ttelefono: $data.clienteVar.telefono !== undefined ? $data.clienteVar.telefono : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
