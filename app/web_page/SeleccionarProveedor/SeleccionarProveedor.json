    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.proveedor ){",
        "\treturn {",
        "\t\t//map proveedor variable to expected task contract input",
        "\t\tproveedorInput: {",
        "\t\t\tid: $data.proveedor.id !== undefined ? $data.proveedor.id : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
